{
  "name": "@koalarx/ui-cli",
  "version": "0.18.0",
  "scripts": {
    "build": "bun scripts/build",
    "build:doc": "cd libs/ui && bun run build:prod",
    "start": "bun run build && bun ./bin/run",
    "ui:start": "cd libs/ui && bun start",
    "generate:command": "bun scripts/generate-command",
    "generate:llms": "node scripts/generate-llms.js",
    "version": "git add -A libs",
    "postversion": "git push && git push --tags",
    "prepare:hotfix": "npm version patch",
    "prepare:feature": "npm version minor",
    "prepare:release": "npm version major",
    "test:cli": "vitest run libs/cli",
    "test:cli:watch": "vitest libs/cli",
    "test:ui": "cd libs/ui && bun run test:unit && bun run e2e",
    "test": "bun run test:cli && bun run test:ui"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      },
      {
        "files": ".dockerignore",
        "options": {
          "parser": "yaml"
        }
      }
    ]
  },
  "packageManager": "bun@1.3.6",
  "dependencies": {
    "@koalarx/utils": "^4.2.3",
    "chalk": "4.1.2",
    "clsx": "^2.1.1",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "25.3.0",
    "@typescript-eslint/eslint-plugin": "8.53.1",
    "@typescript-eslint/parser": "8.53.1",
    "@vitest/coverage-v8": "4.0.16",
    "@vitest/eslint-plugin": "1.6.6",
    "eslint": "9.39.2",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.5",
    "prettier": "3.7.4",
    "typescript": "5.9.2",
    "typescript-eslint": "8.53.1"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "bin": {
    "kl": "./bin/run.js"
  },
  "keywords": [
    "koalarx",
    "ui",
    "angular",
    "components",
    "library",
    "tailwindcss",
    "daisyui"
  ]
}
